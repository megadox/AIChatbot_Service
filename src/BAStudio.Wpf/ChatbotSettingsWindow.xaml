<Window x:Class="BAStudio.Wpf.ChatbotSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="챗봇 설정"
        Width="520"
        Height="440"
        MinWidth="460"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="답변 서비스 모드"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,8" />

        <ComboBox Grid.Row="1"
                  ItemsSource="{Binding Modes}"
                  SelectedValue="{Binding Mode, Mode=TwoWay}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Label"
                  Width="180"
                  Height="30"
                  HorizontalAlignment="Left" />

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Padding="14"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="6"
                MinHeight="190">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="온라인 서비스"
                           FontWeight="SemiBold"
                           Foreground="#111827" />

                <TextBlock Grid.Row="1"
                           Text="API 주소"
                           Foreground="#374151"
                           Margin="0,14,0,6" />
                <TextBox Grid.Row="2"
                         Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="32"
                         Padding="8,4"
                         ToolTip="예: https://chatbot.example.com" />

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="API 토큰"
                               Foreground="#374151"
                               Margin="0,0,0,6" />
                    <PasswordBox x:Name="ApiTokenBox"
                                 Grid.Row="1"
                                 Height="32"
                                 Padding="8,4"
                                 PasswordChanged="ApiTokenBox_OnPasswordChanged" />
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="#6B7280"
                   TextWrapping="Wrap"
                   Text="오프라인 모드는 로컬 KB와 로컬 답변 엔진을 사용합니다. 온라인 모드는 WPF가 화면만 담당하고 답변은 API 서버에서 생성합니다." />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="저장"
                    MinWidth="88"
                    Height="34"
                    IsDefault="True"
                    Click="Save_OnClick" />
            <Button Content="취소"
                    MinWidth="88"
                    Height="34"
                    Margin="8,0,0,0"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

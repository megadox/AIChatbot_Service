<Window x:Class="BAStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BA-Studio AI Chatbot" Height="720" Width="1040"
        MinHeight="560" MinWidth="780"
        Background="#F6F7F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="CopyIconButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,-4,-4,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6" />
                                <Setter Property="BorderBrush" Value="#E5E7EB" />
                                <Setter Property="Foreground" Value="#111827" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1F2937" Padding="20,0">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="BA-Studio AI Chatbot"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AnswerModeText}"
                               Foreground="#D1D5DB"
                               FontSize="11"
                               Margin="10,2,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#D1D5DB"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Foreground="#F9FAFB"
                               Margin="12,0,0,0"
                               Width="28"
                               Height="28"
                               LineHeight="20"
                               LineStackingStrategy="BlockLineHeight"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Cursor="Hand"
                               ToolTip="챗봇 설정"
                               MouseLeftButtonUp="SettingsButton_OnClick" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0"
                Padding="12">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="+ 새 대화"
                            Command="{Binding NewSessionCommand}"
                            Margin="0" />
                    <Button Grid.Column="1"
                            Content="삭제"
                            Command="{Binding DeleteSessionCommand}" />
                </Grid>

                <ListBox ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="SessionListItem_OnPreviewMouseRightButtonDown" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="대화 파일 위치 열기"
                                                  Command="{Binding PlacementTarget.Tag.OpenSelectedSessionFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8"
                                    Margin="0,0,0,6"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Background="#F9FAFB">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#111827"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DisplayUpdatedAt}"
                                               Foreground="#6B7280"
                                               FontSize="11"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      Grid.Column="1"
                      Padding="20"
                      VerticalScrollBarVisibility="Auto"
                      Loaded="ChatScrollViewer_OnLoaded"
                      SizeChanged="ChatScrollViewer_OnSizeChanged">
            <ItemsControl ItemsSource="{Binding SelectedSession.Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding Background}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Stretch">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Role}"
                                               Foreground="#4B5563"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource CopyIconButtonStyle}"
                                            Command="{Binding CopyCommand}"
                                            ToolTip="{Binding CopyToolTip}"
                                            Visibility="{Binding HasText, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13"
                                                   TextAlignment="Center" />
                                    </Button>
                                </Grid>
                                <TextBox Text="{Binding Text}"
                                         Foreground="#111827"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0"
                                         FontSize="13"
                                         MinHeight="20"
                                         VerticalScrollBarVisibility="Disabled" />
                                <Expander Header="자세히"
                                          Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Margin="0,10,0,0">
                                    <TextBox Text="{Binding DetailsText}"
                                             Foreground="#374151"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="#F9FAFB"
                                             Padding="8"
                                             FontSize="12"
                                             MaxHeight="220"
                                             VerticalScrollBarVisibility="Auto" />
                                </Expander>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0"
                      Grid.Column="0"
                      Grid.ColumnSpan="4"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <TextBlock Text="질문 유형"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"
                                   Margin="0,0,8,0" />
                        <ComboBox ItemsSource="{Binding QuestionTypes}"
                                  SelectedValue="{Binding SelectedSession.QuestionType, Mode=TwoWay}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  Width="160"
                                  Height="28"
                                  Margin="0,0,18,0" />
                        <CheckBox Content="문맥 유지"
                                  IsChecked="{Binding SelectedSession.IsContextRetained}"
                                  Margin="0,0,18,0" />
                        <CheckBox Content="웹 검색"
                                  IsChecked="{Binding SelectedSession.IsWebSearchEnabled}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AppVersionText}"
                               Foreground="#6B7280"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                </Grid>

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Text="{Binding SelectedSession.InputText, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="44"
                         MaxHeight="120"
                         Padding="12"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputBox_OnKeyDown" />

                <Button Grid.Row="1"
                        Grid.Column="1"
                        Content="전송"
                        Command="{Binding SendCommand}"
                        IsEnabled="{Binding CanSend}" />

                <Button Grid.Row="1"
                        Grid.Column="2"
                        Content="답변"
                        Command="{Binding CorrectAnswerCommand}"
                        IsEnabled="{Binding CanCorrectAnswer}" />

                <Button Grid.Row="1"
                        Grid.Column="3"
                        Content="취소"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsBusy}" />

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="0,10,0,0"
                        Padding="10"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="6"
                        MaxHeight="110">
                    <TextBox Text="{Binding SelectedSession.ProcessLogText, Mode=OneWay}"
                             Foreground="#374151"
                             FontSize="12"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

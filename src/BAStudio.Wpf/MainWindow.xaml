<Window x:Class="BAStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BA Chatbot"
        Height="720"
        Width="1040"
        MinHeight="560"
        MinWidth="780"
        FontFamily="Segoe UI"
        Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#667085" />
        <SolidColorBrush x:Key="BorderBrushBase" Color="#E4E7EC" />
        <SolidColorBrush x:Key="BrandBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="BrandSoftBrush" Color="#EFF6FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />

        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BrandBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BrandBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="CopyIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="8,-3,-4,0" />
        </Style>

        <Style x:Key="ChipCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root"
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="12,0,34,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding ItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False" />
                            <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{StaticResource TextSecondaryBrush}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  IsHitTestVisible="False" />
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      Margin="0,4,0,0">
                                    <Border Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrushBase}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <ScrollViewer Margin="4"
                                                      SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#CBD5E1" />
                                <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#93C5FD" />
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBEAFE" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="SessionListItem_OnPreviewMouseRightButtonDown" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="대화 파일 위치 열기"
                                  Command="{Binding PlacementTarget.Tag.OpenSelectedSessionFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="0,0,0,1"
                Padding="22,0">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="34"
                            Height="34"
                            Background="{StaticResource BrandBrush}"
                            CornerRadius="9"
                            Margin="0,0,12,0">
                        <TextBlock Text="BA"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="BA Chatbot"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Border Background="{StaticResource BrandSoftBrush}"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,3"
                                    Margin="10,1,0,0">
                                <TextBlock Text="{Binding AnswerModeText}"
                                           Foreground="#1D4ED8"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="BA-Studio와 BA-Assist 사용을 돕는 AI Assistant"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Background="#F0FDF4"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="9,5"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7"
                                     Height="7"
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,7,0" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#166534"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding AppVersionText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            ToolTip="챗봇 설정"
                            Click="SettingsButton_OnClick">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Grid.RowSpan="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="0,0,1,0"
                Padding="16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Button Content="+ 새 대화"
                            Command="{Binding NewSessionCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0"
                            Height="40" />
                    <Button Content="선택 대화 삭제"
                            Command="{Binding DeleteSessionCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"
                            Height="34" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ItemContainerStyle="{StaticResource SessionListBoxItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <DockPanel Grid.Row="1"
                                           Margin="0,6,0,0">
                                    <TextBlock Text="{Binding DisplayUpdatedAt}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               DockPanel.Dock="Left" />
                                    <TextBlock Text="{Binding MessageCountText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      Grid.Column="1"
                      Padding="28,24"
                      VerticalScrollBarVisibility="Auto"
                      Loaded="ChatScrollViewer_OnLoaded"
                      SizeChanged="ChatScrollViewer_OnSizeChanged">
            <ItemsControl ItemsSource="{Binding SelectedSession.Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,16">
                            <Border Background="{Binding Background}"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    MaxWidth="{Binding BubbleMaxWidth}"
                                    HorizontalAlignment="{Binding BubbleAlignment}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayRole}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DisplayCreatedAt}"
                                                       Foreground="#98A2B3"
                                                       FontSize="11"
                                                       Margin="8,1,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource CopyIconButtonStyle}"
                                                Command="{Binding CopyCommand}"
                                                ToolTip="{Binding CopyToolTip}"
                                                Visibility="{Binding HasText, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="13"
                                                       TextAlignment="Center" />
                                        </Button>
                                    </Grid>
                                    <TextBox Text="{Binding Text}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0"
                                             FontSize="14"
                                             MinHeight="20"
                                             VerticalScrollBarVisibility="Disabled" />
                                    <Expander Header="검색/처리 근거"
                                              Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Margin="0,12,0,0"
                                              Foreground="{StaticResource TextSecondaryBrush}">
                                        <TextBox Text="{Binding DetailsText}"
                                                 Foreground="#344054"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Background="{StaticResource SurfaceMutedBrush}"
                                                 Padding="10"
                                                 FontSize="12"
                                                 MaxHeight="220"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding QuestionTypes}"
                              SelectedValue="{Binding SelectedSession.QuestionType, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              Width="168"
                              Height="30"
                              Margin="0,0,10,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <CheckBox Content="문맥 유지"
                                  Style="{StaticResource ChipCheckBoxStyle}"
                                  IsChecked="{Binding SelectedSession.IsContextRetained}" />
                        <CheckBox Content="웹 검색"
                                  Style="{StaticResource ChipCheckBoxStyle}"
                                  IsChecked="{Binding SelectedSession.IsWebSearchEnabled}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrushBase}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox Text="{Binding SelectedSession.InputText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="44"
                                     MaxHeight="120"
                                     Padding="0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"
                                     VerticalScrollBarVisibility="Auto"
                                     KeyDown="InputBox_OnKeyDown" />
                            <TextBlock Text="BA-Studio 기능, 액티비티, BA-Assist 사용법을 질문하세요."
                                       Foreground="#98A2B3"
                                       FontSize="14"
                                       Margin="2,2,0,0"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SelectedSession.HasNoInputText, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>

                        <Button Grid.Column="1"
                                Content="전송"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SendCommand}"
                                IsEnabled="{Binding CanSend}"
                                Margin="12,0,0,0" />

                        <Button Grid.Column="2"
                                Content="피드백"
                                Command="{Binding CorrectAnswerCommand}"
                                IsEnabled="{Binding CanCorrectAnswer}" />

                        <Button Grid.Column="3"
                                Content="중지"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding IsBusy}" />
                    </Grid>
                </Border>

                <Expander Grid.Row="2"
                          Header="처리 과정"
                          Margin="0,10,0,0"
                          Foreground="{StaticResource TextSecondaryBrush}">
                    <Border Margin="0,8,0,0"
                            Padding="10"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="8"
                            MaxHeight="110">
                        <TextBox Text="{Binding SelectedSession.ProcessLogText, Mode=OneWay}"
                                 Foreground="#344054"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Expander>
            </Grid>
        </Border>
    </Grid>
</Window>
